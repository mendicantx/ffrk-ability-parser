<div class="px-4 py-2">
<div class="d-flex align-items-baseline gap-3 mb-3">
  <h4 class="mb-0">Dashboard</h4>
  <small id="load-msg" class="text-secondary">Loading…</small>
</div>

<div id="sheets-area"></div>
<div id="comparison-area"></div>
<div id="battlejs-area"></div>
</div>

<script>
// ── Constant map extraction (same logic as ability_parser) ───────────────────
function extractConstantMap(js, name) {
  const marker = name + ':{';
  const merged = {};
  let searchFrom = 0;
  while (true) {
    const idx = js.indexOf(marker, searchFrom);
    if (idx === -1) break;
    let depth = 0, start = idx + name.length + 1, i = start;
    for (; i < js.length; i++) {
      if (js[i] === '{') depth++;
      else if (js[i] === '}') { depth--; if (depth === 0) break; }
    }
    const block = js.slice(start + 1, i);
    for (const m of block.matchAll(/([A-Z][A-Z0-9_]*):(\d+)/g)) {
      merged[m[1]] = parseInt(m[2]);
    }
    searchFrom = idx + 1;
  }
  return merged;
}

// ── Render sheet tabs ────────────────────────────────────────────────────────
function renderSheets(sheetData) {
  const area = document.getElementById('sheets-area');
  let html = '';
  for (const [name, rows] of Object.entries(sheetData)) {
    const label = name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    html += `<details class="mb-2">
      <summary class="user-select-none fw-semibold py-1">
        ${label}
        <span class="badge bg-secondary fw-normal ms-1">${rows.length} rows</span>
      </summary>`;
    if (rows.length > 0) {
      const cols = Object.keys(rows[0]);
      const thead = cols.map(c => `<th class="text-nowrap">${c}</th>`).join('');
      const tbody = rows.map(r =>
        `<tr>${cols.map(c => `<td>${r[c] ?? ''}</td>`).join('')}</tr>`
      ).join('');
      html += `<div class="overflow-auto mt-2 mb-3" style="max-height:400px">
        <table class="table table-sm table-bordered table-striped-columns mb-0" style="font-size:12px">
          <thead class="table-dark sticky-top"><tr>${thead}</tr></thead>
          <tbody>${tbody}</tbody>
        </table>
      </div>`;
    } else {
      html += `<p class="text-secondary fst-italic mt-2">No rows loaded for ${label}.</p>`;
    }
    html += `</details>`;
  }
  area.innerHTML = html || '<p class="text-secondary fst-italic">No sheet data loaded.</p>';
}

// ── Render status ailment comparison ────────────────────────────────────────
function renderComparison(statusMap, statusRows) {
  const normalize = s => s.toLowerCase().replace(/[\s_]+/g, '_');
  const sample  = statusRows[0] ? Object.keys(statusRows[0]) : [];
  const nameCol = sample.find(k => normalize(k) === 'coded_name');
  const idCol   = sample.find(k => normalize(k) === 'id');

  const csvByName = {};
  for (const row of statusRows) {
    const key = nameCol && row[nameCol]?.trim();
    if (!key) continue;
    csvByName[key] = idCol ? parseInt(row[idCol]) : null;
  }

  const matched = [], mismatch = [], jsOnly = [], csvOnly = [];
  for (const [name, jsId] of Object.entries(statusMap)) {
    if (name in csvByName) {
      if (csvByName[name] === jsId) matched.push({ name, id: jsId });
      else                          mismatch.push({ name, jsId, csvId: csvByName[name] });
    } else {
      jsOnly.push({ name, id: jsId });
    }
  }
  for (const [name, csvId] of Object.entries(csvByName)) {
    if (!(name in statusMap)) csvOnly.push({ name, id: csvId });
  }
  const sort = arr => arr.sort((a, b) => a.name < b.name ? -1 : 1);
  sort(matched); sort(mismatch); sort(jsOnly); sort(csvOnly);

  function twoColTable(rows) {
    return `<table class="table table-sm table-bordered" style="font-size:12px">
      <thead class="table-dark"><tr><th>Coded Name</th><th>ID</th></tr></thead>
      <tbody>${rows.map(r => `<tr><td>${r.name}</td><td>${r.id}</td></tr>`).join('')}</tbody>
    </table>`;
  }

  const badges = [
    `<span class="badge bg-success fw-normal ms-1">✓ ${matched.length} matched</span>`,
    mismatch.length ? `<span class="badge bg-warning text-dark fw-normal ms-1">⚠ ${mismatch.length} ID mismatch</span>` : '',
    jsOnly.length   ? `<span class="badge bg-info fw-normal ms-1">● ${jsOnly.length} JS only</span>` : '',
    csvOnly.length  ? `<span class="badge bg-secondary fw-normal ms-1">● ${csvOnly.length} CSV only</span>` : '',
  ].join('');

  let inner = '';
  if (mismatch.length) {
    inner += `<h6 class="text-warning">⚠ ID Mismatch (${mismatch.length})</h6>
    <div class="overflow-auto mb-3">
      <table class="table table-sm table-bordered" style="font-size:12px">
        <thead class="table-dark"><tr><th>Coded Name</th><th>JS ID</th><th>CSV ID</th></tr></thead>
        <tbody>${mismatch.map(r => `<tr><td>${r.name}</td><td>${r.jsId}</td><td>${r.csvId}</td></tr>`).join('')}</tbody>
      </table>
    </div>`;
  }
  if (jsOnly.length) {
    inner += `<h6 class="text-info">In JS only — not in Status CSV (${jsOnly.length})</h6>
    <div class="overflow-auto mb-3">${twoColTable(jsOnly)}</div>`;
  }
  if (csvOnly.length) {
    inner += `<h6 class="text-secondary">In CSV only — not in JS (${csvOnly.length})</h6>
    <div class="overflow-auto mb-3">${twoColTable(csvOnly)}</div>`;
  }
  if (matched.length) {
    inner += `<details>
      <summary class="user-select-none text-success py-1">✓ Matched (${matched.length})</summary>
      <div class="overflow-auto mt-2 mb-3" style="max-height:300px">${twoColTable(matched)}</div>
    </details>`;
  }

  document.getElementById('comparison-area').innerHTML = `
    <details class="mb-2">
      <summary class="user-select-none fw-semibold py-1">
        Status Ailment Comparison: JS vs CSV ${badges}
      </summary>
      <div class="mt-2">${inner}</div>
    </details>`;
}

// ── Render battle.js section ─────────────────────────────────────────────────
function renderBattleJs(jsText) {
  document.getElementById('battlejs-area').innerHTML = `
    <details class="mb-2">
      <summary class="user-select-none fw-semibold py-1">
        battle.js
        <span class="badge bg-secondary fw-normal ms-1">${jsText.length.toLocaleString()} chars</span>
      </summary>
      <p class="text-secondary fst-italic mt-2" style="font-size:13px">
        Raw JS available in the browser console on the
        <a href="/ability_parser">Ability Parser</a> page via <code>rawBattleJs</code>.
      </p>
    </details>`;
}

// ── Boot ─────────────────────────────────────────────────────────────────────
(async function init() {
  const msgEl = document.getElementById('load-msg');
  try {
    const [sheetResp, jsResp] = await Promise.all([
      fetch('/ability_parser/sheet_data'),
      fetch('/ability_parser/battle_js'),
    ]);
    if (!sheetResp.ok) throw new Error(`sheet_data HTTP ${sheetResp.status}`);
    if (!jsResp.ok)    throw new Error(`battle_js HTTP ${jsResp.status}`);

    const sheetData = await sheetResp.json();
    const jsText    = await jsResp.text();

    renderSheets(sheetData);
    renderBattleJs(jsText);

    const statusMap = extractConstantMap(jsText, 'STATUS_AILMENTS_TYPE');
    renderComparison(statusMap, sheetData.status ?? []);

    const totalRows = Object.values(sheetData).reduce((s, r) => s + r.length, 0);
    msgEl.textContent = `${totalRows.toLocaleString()} rows across ${Object.keys(sheetData).length} sheets · ${jsText.length.toLocaleString()} chars JS`;
  } catch(e) {
    msgEl.textContent = 'Error: ' + e.message;
    msgEl.className = 'text-danger';
  }
})();
</script>
