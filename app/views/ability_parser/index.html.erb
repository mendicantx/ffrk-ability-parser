    .sbp-translate-btn { background: #1e3a1e; color: #4ec9b0; border: 1px solid #2a5a2a; padding: 1px 6px; font-family: monospace; font-size: 10px; cursor: pointer; border-radius: 2px; margin-left: 6px; vertical-align: middle; }
    .sbp-translate-btn:hover:not(:disabled) { background: #153015; }
